---
// EventsItem.astro
const {
    event_name, 
    event_date, 
    guests_byEvents, 
    event_description, 
    Id, 
    event_time,
} = Astro.props;
---

<li id={Id} class="flex flex-col gap-4 p-2 justify-between border border-pink-700 rounded-md items-center">
    
    <div class="flex flex-wrap md:flex-nowrap gap-2 flex-col w-full p-2">
     
        <input class="w-full bg-pink-500 rounded-md p-2 outline-none text-white font-bold" type="text" value={event_name} readonly>
        <label for="event_date">Fecha del evento:</label>
        <input id="event_date" class="w-full bg-gray-100 rounded-md p-2 outline-none" type="text" value={event_date} readonly>
        <label for="event_time">Hora:</label>
        <input id="event_time" class="w-full bg-gray-100 rounded-md p-2 outline-none" type="text" value={event_time} readonly>
        <label for="guests_byEvents">Invitados:</label>
        <input id="guests_byEvents" class="w-full bg-gray-100 rounded-md p-2 outline-none" type="text" value={guests_byEvents} readonly>
       
        <label for="event_description">Descripción:</label> 
        <input id="event_description" class="w-full bg-gray-100 rounded-md p-2 outline-none" type="text" value={event_description} readonly>
    </div>
    <div class="w-full mt-4 border-t border-gray-200 pt-4">
    
    <div id="comments-list" class="flex flex-col gap-2 mb-4 max-h-48 overflow-y-auto p-1">
        <template id="comment-template">
            <div class="bg-gray-50 p-2 rounded-md border border-gray-200 text-sm flex justify-between items-start">
                <div class="flex-1">
                    <p class="font-bold text-pink-600 mb-1">Usuario</p>
                    <p class="text-gray-700 comment-text">Contenido del comentario...</p>
                </div>
                <div class="flex gap-2 ml-2">
                    <button class="text-gray-400 hover:text-blue-500 transition-colors">✎</button>
                    <button class="text-gray-400 hover:text-red-500 transition-colors">✕</button>
                </div>
            </div>
        </template>
    </div>

    <button 
    id="btn-comments" 
    class="mt-2 text-pink-700 font-semibold text-sm hover:underline self-start"
>
    Ver comentarios
</button>

<div id="comments-section" class="hidden w-full mt-4 border-t border-gray-200 pt-4">
    <h3 class="text-pink-700 font-bold mb-2 text-sm">Comentarios</h3>
    
    <div id="comments-list" class="flex flex-col gap-2 mb-4 max-h-48 overflow-y-auto">
        <template id="comment-template">
            <div class="bg-gray-50 p-2 rounded-md border border-gray-200 text-xs flex justify-between">
                <p class="text-gray-700 comment-text"></p>
                <div class="flex gap-2 ml-2">
                    <button class="edit-comment text-blue-400">✎</button>
                    <button class="delete-comment text-red-400">✕</button>
                </div>
            </div>
        </template>
    </div>

    <form id="comment-form" class="flex flex-col gap-2">
        <textarea 
            name="content"
            class="w-full bg-gray-100 rounded-md p-2 text-xs outline-none border focus:border-pink-500" 
            placeholder="Escribe un comentario..."
            rows="2"
            required
        ></textarea>
        <button type="submit" class="bg-pink-600 text-white py-1 px-3 rounded-md text-xs self-end">
            Publicar
        </button>
    </form>
</div>
</li>

